<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        x:Class="FastaAnalyzer.Widoki.OknoGlowne"
        Title="Analizator FASTA"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="600">

    <Grid RowDefinitions="Auto,*"
          ColumnDefinitions="320,*"
          Margin="16"
          RowSpacing="12"
          ColumnSpacing="12">

        <StackPanel Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Spacing="10">

            <Button Content="Wczytaj pliki FASTA"
                    Click="WczytajPlikiFasta_Click"
                    Padding="14,8"/>

            <Button Content="Eksport CSV"
                    Click="EksportCsv_Click"
                    Padding="14,8"/>

            <Button Content="Eksport JSON"
                    Click="EksportJson_Click"
                    Padding="14,8"/>

            <TextBlock x:Name="TekstStatusu"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Text="Gotowe."/>
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">

            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Sekwencje"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <ListBox x:Name="ListaSekwencji"
                         SelectionChanged="ListaSekwencji_SelectionChanged"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              Grid.Column="1"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="12">

            <Border Grid.Row="0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">

                <StackPanel>
                    <TextBlock Text="Szczegóły wybranej sekwencji"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="TekstSzczegolow"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Text="Wybierz sekwencję z listy po lewej stronie."/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">

                <StackPanel>
                    <TextBlock Text="Podgląd sekwencji"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="PodgladSekwencji"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="120"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">

                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="Wykres długości sekwencji"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <lvc:CartesianChart x:Name="WykresDlugosci"
                                        Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>